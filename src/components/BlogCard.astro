---
interface Props {
  title: string;
  description: string;
  category: string;
  url: string;
  image?: string;
  icon?: string;
}

const { title, description, category, url, image, icon = "🏗️" } = Astro.props;
---

<a href={url} class="block bg-brand-light rounded-2xl overflow-hidden hover:shadow-md transition-shadow group cursor-pointer border border-transparent hover:border-gray-200">
  <div class="h-48 bg-gray-200 overflow-hidden relative">
    <div class="absolute inset-0 bg-brand opacity-10 group-hover:opacity-0 transition-opacity z-10"></div>
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-4xl text-gray-400 bg-gray-100">
        {icon}
      </div>
    )}
  </div>
  <div class="p-6">
    <div class="text-accent text-xs font-bold uppercase tracking-wider mb-2">{category}</div>
    <h3 class="text-lg font-bold text-dark mb-2 group-hover:text-accent transition-colors line-clamp-2">{title}</h3>
    <p class="text-gray-500 text-sm line-clamp-3">{description}</p>
  </div>
</a>
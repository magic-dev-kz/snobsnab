---
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  description: string;
  category: string;
  url: string;
  image?: string;
}

const { title, description, category, url, image } = Astro.props;
---

<a href={url} class="block group h-full">
  <div class="brutal-card h-full flex flex-col p-0 overflow-hidden">
    <!-- Изображение с жестким фильтром и бордером -->
    <div class="relative h-48 border-b-2 border-brand bg-brand-light overflow-hidden">
      {image ? (
        <img src={image} alt={title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-300" />
      ) : (
        <div class="w-full h-full bg-[#1A1A1A] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPjxyZWN0IHdpZHRoPSI4IiBoZWlnaHQ9IjgiIGZpbGw9IiMxQTFBMUEiPjwvcmVjdD48cGF0aCBkPSJNMCAwTDggOFpNOCAwTDAgOFoiIHN0cm9rZT0iIzIyMjIyMiIgc3Ryb2tlLXdpZHRoPSIxIj48L3BhdGg+PC9zdmc+')] opacity-20"></div>
      )}
      <!-- Бейдж категории -->
      <div class="absolute top-4 left-4 bg-accent text-white px-2 py-1 font-mono text-xs font-bold uppercase border-2 border-brand shadow-[2px_2px_0px_#1A1A1A]">
        {category}
      </div>
    </div>
    
    <!-- Текст -->
    <div class="p-6 flex flex-col flex-grow bg-white">
      <h3 class="text-xl font-bold uppercase tracking-tight text-brand mb-3 leading-tight group-hover:text-accent transition-colors line-clamp-2">
        {title}
      </h3>
      <p class="text-sm text-gray-600 line-clamp-3 mb-4 flex-grow font-medium">
        {description}
      </p>
      
      <!-- Читать далее (Стрелка) -->
      <div class="mt-auto flex items-center gap-2 text-brand font-bold uppercase text-xs font-mono group-hover:text-accent transition-colors">
        <span>Читать</span>
        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </div>
    </div>
  </div>
</a>

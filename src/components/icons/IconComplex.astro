---
interface Props { class?: string; }
const { class: className = 'w-8 h-8' } = Astro.props;
---
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter" class={className}>
  <rect x="4" y="2" width="16" height="20" />
  <path d="M8 6h8" />
  <path d="M8 12h8" />
  <path d="M8 18h8" />
  <rect x="4" y="2" width="16" height="8" fill="currentColor" stroke="none" fill-opacity="0.1" />
</svg>

---
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { 
  title, 
  description = 'СнобСнаб - стройматериалы по ценам заводов в Кемерово. Доставка до двери. На 30% дешевле магазинов.', 
  ogImage = '/og-image.jpg',
  canonical
} = Astro.props;

const siteUrl = 'https://snobsnab.ru';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="стройматериалы Кемерово, ремонт квартиры, материалы для ремонта, сантехника, керамика, краски, обои, освещение, покрытия полов, доставка стройматериалов, Кузбасс" />
    <meta name="author" content="СнобСнаб" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="СнобСнаб" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Geo -->
    <meta name="geo.region" content="RU-KEM" />
    <meta name="geo.placename" content="Кемерово" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Подключаем строгие шрифты: Inter для текста, JetBrains Mono для цифр и акцентов -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;800&family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "СнобСнаб",
      "description": "Стройматериалы по ценам заводов. Доставка до двери в Кемерово и Кузбассе.",
      "url": "https://snobsnab.ru",
      "telephone": "+79132848489",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "ул. Базовая 5Б, офис 403",
        "addressLocality": "Кемерово",
        "addressRegion": "Кемеровская область",
        "postalCode": "650000",
        "addressCountry": "RU"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "55.3545",
        "longitude": "86.0876"
      },
      "openingHours": "Mo-Su 10:00-19:00",
      "priceRange": "$$"
    })} />
    
    <slot name="head" />

    <style is:global>
      body {
        font-family: 'Inter', sans-serif;
      }
      .font-mono {
        font-family: 'JetBrains Mono', monospace;
      }
    </style>
  </head>
  <body class="bg-brand-light text-dark antialiased min-h-screen flex flex-col">

    <Header />

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer Brutal -->
    <footer class="bg-brand text-white border-t-8 border-accent pt-16 pb-8 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-4 gap-12 border-b-2 border-white/20 pb-12">
          
          <div class="md:col-span-2">
            <div class="bg-white text-brand inline-block font-extrabold text-3xl px-4 py-2 tracking-tighter uppercase mb-6 border-2 border-brand shadow-[4px_4px_0px_#FF7416]">
              СНОБ<br/>СНАБ
            </div>
            <p class="text-sm font-mono leading-relaxed mb-6 max-w-sm text-gray-400">
              СТРОЙМАТЕРИАЛЫ ПО ЦЕНАМ ЗАВОДОВ.<br/>
              БЕЗ ПОСРЕДНИКОВ. БЕЗ СКЛАДОВ.<br/>
              ПРЯМО НА ВАШ ОБЪЕКТ.
            </p>
            <div class="text-xs font-mono text-gray-500 space-y-1 border-l-2 border-accent pl-3">
              <p>ИНН: 422377462006</p>
              <p>ОГРН: 326420500027354</p>
            </div>
          </div>

          <div>
            <h4 class="font-bold mb-6 uppercase tracking-widest text-accent text-sm border-b-2 border-white/20 pb-2 inline-block">Навигация</h4>
            <ul class="space-y-4 font-bold uppercase text-sm">
              <li><a href="/#catalog" class="hover:text-accent hover:pl-2 transition-all">Каталог</a></li>
              <li><a href="/#advantages" class="hover:text-accent hover:pl-2 transition-all">Почему мы</a></li>
              <li><a href="/blog" class="hover:text-accent hover:pl-2 transition-all">Блог</a></li>
              <li><a href="/about" class="hover:text-accent hover:pl-2 transition-all">О нас</a></li>
              <li><a href="/#contact" class="hover:text-accent hover:pl-2 transition-all text-accent">Смета</a></li>
            </ul>
          </div>

          <div>
            <h4 class="font-bold mb-6 uppercase tracking-widest text-accent text-sm border-b-2 border-white/20 pb-2 inline-block">Контакты</h4>
            <ul class="space-y-4 font-mono text-sm">
              <li>
                <div class="text-gray-500 mb-1 text-xs">Адрес:</div>
                г. Кемерово, ул. Базовая 5Б,<br/>офис 403
              </li>
              <li>
                <div class="text-gray-500 mb-1 text-xs">Телефон:</div>
                <a href="tel:+79132848489" class="text-xl font-bold hover:text-accent transition-colors">+7 913 284-84-89</a>
              </li>
              <li>
                <div class="text-gray-500 mb-1 text-xs">Режим работы:</div>
                Ежедневно 10:00 – 19:00
              </li>
            </ul>
          </div>
        </div>

        <div class="mt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-mono text-gray-500">
          <span>© 2026 SNOBSNAB. ALL RIGHTS RESERVED.</span>
          <a href="#" class="hover:text-white transition-colors uppercase">Политика конфиденциальности</a>
        </div>
      </div>
    </footer>
  </body>
</html>

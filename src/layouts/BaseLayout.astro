---
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'СнобСнаб — стройматериалы с доставкой на дом в Кемерово. Прямые поставки от производителей. Цены ниже рынка.' } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <slot name="head" />

    <!-- Yandex.Metrika -->
    <script type="text/javascript">
      (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
      k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
      (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");

      ym(107239027, "init", {
        clickmap:true,
        trackLinks:true,
        accurateTrackBounce:true,
        webvisor:true
      });
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/107239027" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
  </head>
  <body class="bg-brand-light text-dark antialiased min-h-screen flex flex-col">

    <Header />

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-gray-400 py-12 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <img src="/logo.png" alt="СнобСнаб" class="h-12 w-auto mb-4 [filter:brightness(0)_invert(1)]" />
            <p class="text-sm leading-relaxed mb-4">Стройматериалы с доставкой на дом. Цены ниже рынка — работаем без складов, делимся прибылью с вами.</p>
            <p class="text-sm">ИНН: 4205000000<br/>ОГРН: 1024200000000</p>
          </div>
          <div>
            <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Меню</h4>
            <ul class="space-y-3">
              <li><a href="/#catalog" class="hover:text-accent transition">Каталог материалов</a></li>
              <li><a href="/#advantages" class="hover:text-accent transition">Почему мы</a></li>
              <li><a href="/blog" class="hover:text-accent transition">База знаний</a></li>
              <li><a href="/#contact" class="hover:text-accent transition">Рассчитать смету</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Контакты</h4>
            <ul class="space-y-3">
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                </span>
                <span>г. Кемерово, ул. Базовая 5Б,<br/>офис 403</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                </span>
                <a href="tel:+79132848489" class="hover:text-accent transition font-bold text-white">+7 913 284-84-89</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </span>
                <span>Ежедневно 10:00 – 19:00</span>
              </li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-12 pt-8 text-center text-sm flex flex-col md:flex-row justify-between items-center gap-4">
          <span>© 2026 СнобСнаб. Все права защищены.</span>
          <a href="#" class="hover:text-white transition">Политика конфиденциальности</a>
        </div>
      </div>
    </footer>
  </body>
</html>

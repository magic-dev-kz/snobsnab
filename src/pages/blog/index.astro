---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('ru-RU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title="Блог о строительстве — СнобСнаб" description="Полезные статьи о стройматериалах, технологиях строительства и экономии. Советы для строителей и заказчиков в Сибири и Кузбассе.">

  <section class="bg-gradient-to-br from-brand to-brand-light text-white py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl lg:text-5xl font-bold mb-4">Блог о строительстве</h1>
      <p class="text-blue-100 text-lg max-w-2xl mx-auto">Полезные статьи о выборе материалов, технологиях и экономии для строителей и заказчиков в Сибири</p>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group block bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300">
            <div class="md:flex">
              <div class="md:w-64 shrink-0 overflow-hidden bg-gray-100">
                {post.data.ogImage ? (
                  <img src={post.data.ogImage} alt={post.data.title} class="w-full h-48 md:h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                ) : (
                  <div class="w-full h-48 md:h-full flex items-center justify-center text-5xl bg-brand-light">
                    {post.data.icon}
                  </div>
                )}
              </div>
              <div class="p-6 md:p-8">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-accent text-sm font-semibold">{post.data.category}</span>
                  <span class="text-gray-300">|</span>
                  <time class="text-gray-400 text-sm">{formatDate(post.data.date)}</time>
                </div>
                <h2 class="text-xl font-bold text-dark mb-2 group-hover:text-brand transition">{post.data.title}</h2>
                <p class="text-gray-500 line-clamp-2">{post.data.description}</p>
                <span class="inline-block mt-4 text-accent font-semibold text-sm group-hover:translate-x-1 transition-transform">Читать статью &rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

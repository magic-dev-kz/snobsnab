---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout 
  title={`${post.data.title} | СнобСнаб`} 
  description={post.data.description}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    
    <!-- Hero Header -->
    <header class="mb-12">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm font-bold uppercase font-mono text-brand hover:text-accent mb-8 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        Назад в блог
      </a>
      
      <div class="flex items-center gap-4 mb-6">
        <span class="bg-accent text-white px-2 py-1 font-mono text-xs font-bold uppercase border-2 border-brand shadow-[2px_2px_0px_#1A1A1A]">
          {post.data.category}
        </span>
        <time class="font-mono text-gray-500 text-sm">{post.data.date}</time>
      </div>

      <h1 class="text-4xl md:text-5xl font-extrabold uppercase tracking-tight text-brand leading-tight mb-6">
        {post.data.title}
      </h1>
      
      <p class="text-xl text-gray-600 font-medium border-l-4 border-accent pl-4">
        {post.data.description}
      </p>
    </header>

    {post.data.ogImage && (
      <div class="mb-12 border-4 border-brand shadow-[8px_8px_0px_#FF7416]">
        <img 
          src={post.data.ogImage} 
          alt={post.data.title} 
          class="w-full h-auto aspect-video object-cover grayscale hover:grayscale-0 transition-all duration-500"
        />
      </div>
    )}

    <!-- Content (Prose Customization for Brutalism) -->
    <div class="prose prose-lg max-w-none 
      prose-headings:font-extrabold prose-headings:uppercase prose-headings:text-brand 
      prose-h2:border-b-2 prose-h2:border-brand prose-h2:pb-2 prose-h2:mt-12
      prose-p:font-medium prose-p:text-gray-800 prose-p:leading-relaxed
      prose-a:font-bold prose-a:text-accent prose-a:no-underline hover:prose-a:underline hover:prose-a:text-brand
      prose-strong:font-extrabold prose-strong:text-brand
      prose-ul:font-medium prose-li:marker:text-accent
      prose-img:border-2 prose-img:border-brand prose-img:shadow-[4px_4px_0px_#1A1A1A]
      prose-blockquote:border-l-4 prose-blockquote:border-accent prose-blockquote:bg-gray-50 prose-blockquote:p-4 prose-blockquote:not-italic prose-blockquote:font-bold">
      <Content />
    </div>

    <!-- Author/CTA Footer -->
    <footer class="mt-16 pt-12 border-t-4 border-brand">
      <div class="bg-brand text-white p-8 border-2 border-accent shadow-[8px_8px_0px_#FF7416] flex flex-col md:flex-row items-center gap-8 justify-between">
        <div>
          <h3 class="text-2xl font-extrabold uppercase mb-2">Нужны материалы?</h3>
          <p class="text-gray-300 font-medium">Сделаем расчет сметы со скидкой до 30% от розничных цен. Без наценок, прямые поставки.</p>
        </div>
        <a href="/#contact" class="brutal-button px-8 py-4 whitespace-nowrap bg-white text-brand border-white hover:bg-accent hover:text-white hover:border-brand">
          Рассчитать смету
        </a>
      </div>
    </footer>

  </article>
</BaseLayout>

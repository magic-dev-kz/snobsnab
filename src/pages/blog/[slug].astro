---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('ru-RU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={`${post.data.title} — СнобСнаб`} description={post.data.description}>
  <Fragment slot="head">
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`https://snobsnab.ru/blog/${post.id}`} />
    {post.data.ogImage && <meta property="og:image" content={`https://snobsnab.ru${post.data.ogImage}`} />}
    <meta property="article:published_time" content={post.data.date} />
  </Fragment>

  <article>
    <header class="bg-gradient-to-br from-brand to-brand-light text-white py-16 lg:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href="/blog" class="inline-flex items-center text-blue-200 hover:text-white transition mb-6 text-sm">&larr; Все статьи</a>
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-accent/20 text-accent px-3 py-1 rounded-full text-sm font-semibold">{post.data.category}</span>
          <time class="text-blue-200 text-sm">{formatDate(post.data.date)}</time>
        </div>
        <h1 class="text-3xl lg:text-4xl font-bold leading-tight">{post.data.title}</h1>
      </div>
    </header>

    {post.data.ogImage && (
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10">
        <div class="rounded-2xl overflow-hidden shadow-xl aspect-[16/9]">
          <img src={post.data.ogImage} alt={post.data.title} class="w-full h-full object-cover" />
        </div>
      </div>
    )}

    <div class="py-12 lg:py-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-lg prose-gray max-w-none
        [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-dark [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-dark [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-gray-600 [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:space-y-1 [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-6
        [&_ol]:space-y-1 [&_ol]:mb-4 [&_ol]:list-decimal [&_ol]:pl-6
        [&_li]:text-gray-600
        [&_strong]:text-dark
        [&_table]:w-full [&_table]:mb-6 [&_table]:border-collapse
        [&_th]:bg-surface [&_th]:text-left [&_th]:p-3 [&_th]:border [&_th]:border-gray-200 [&_th]:font-semibold [&_th]:text-dark [&_th]:text-sm
        [&_td]:p-3 [&_td]:border [&_td]:border-gray-200 [&_td]:text-gray-600 [&_td]:text-sm
        [&_a]:text-accent [&_a]:underline [&_a]:hover:text-accent-hover
        [&_blockquote]:border-l-4 [&_blockquote]:border-accent [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-gray-500
      ">
        <Content />
      </div>
    </div>

    <div class="border-t border-gray-200 py-12">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-surface rounded-2xl p-8 text-center">
          <h2 class="text-2xl font-bold text-dark mb-3">Нужны стройматериалы?</h2>
          <p class="text-gray-500 mb-6">Оставьте заявку — подготовим КП с оптимальными ценами за 24 часа</p>
          <a href="/#contact" class="inline-block bg-accent text-dark font-bold px-8 py-3 rounded-xl hover:bg-accent-hover transition shadow-lg">Запросить КП</a>
        </div>
      </div>
    </div>
  </article>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="О компании СнобСнаб - стройматериалы по ценам заводов в Кемерово" 
  description="СнобСнаб - компания по продаже строительных и отделочных материалов по ценам производителей. Наша миссия - дать людям больше за меньшие деньги."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Hero -->
      <div class="brutal-card p-8 lg:p-12 bg-[#1A1A1A] text-white mb-12 relative overflow-hidden">
        <div class="absolute -right-24 -bottom-24 w-[400px] h-[400px] opacity-[0.08] pointer-events-none">
          <svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <path fill="#FF7416" d="M45.8 250.44c0,-18.73 2.4,-36.83 7.22,-54.3 4.82,-17.48 11.68,-33.79 20.6,-48.95 8.92,-15.16 19.61,-28.98 32.01,-41.46 12.4,-12.48 26.12,-23.18 41.28,-32.01 15.16,-8.83 31.48,-15.69 48.86,-20.6 17.39,-4.9 35.49,-7.31 54.39,-7.31 18.72,0 36.82,2.41 54.21,7.31 17.38,4.9 33.61,11.77 48.77,20.6 15.16,8.83 28.98,19.53 41.46,32.01 12.48,12.48 23.18,26.3 32.01,41.46 8.83,15.16 15.69,31.48 20.6,48.95 4.91,17.48 7.31,35.58 7.31,54.3 0,18.9 -2.4,37 -7.31,54.39 -4.9,17.39 -11.77,33.62 -20.6,48.68 -8.83,15.07 -19.53,28.8 -32.01,41.19 -12.49,12.4 -26.31,23.1 -41.46,32.01 -15.16,8.92 -31.39,15.78 -48.77,20.6 -17.39,4.82 -35.49,7.22 -54.21,7.22 -18.9,0 -37,-2.41 -54.39,-7.22 -17.39,-4.82 -33.7,-11.68 -48.86,-20.6 -15.16,-8.91 -28.89,-19.61 -41.28,-32.01 -12.4,-12.39 -23.09,-26.12 -32.01,-41.19 -8.92,-15.07 -15.78,-31.3 -20.6,-48.68 -4.82,-17.39 -7.22,-35.49 -7.22,-54.39zm73.29 0c0,18.55 3.39,35.84 10.07,51.89 6.69,16.14 15.87,30.23 27.64,42.18 11.77,12.04 25.68,21.49 41.64,28.44 15.96,6.95 33.17,10.43 51.72,10.43 18.37,0 35.58,-3.48 51.53,-10.43 15.96,-6.96 29.79,-16.41 41.55,-28.44 11.77,-11.95 21.05,-26.04 27.82,-42.18 6.78,-16.05 10.16,-33.35 10.16,-51.89 0,-18.37 -3.39,-35.67 -10.16,-51.89 -6.77,-16.32 -16.05,-30.49 -27.82,-42.44 -11.77,-12.04 -25.59,-21.58 -41.55,-28.62 -15.96,-7.04 -33.17,-10.52 -51.53,-10.52 -18.55,0 -35.76,3.48 -51.72,10.52 -15.96,7.05 -29.87,16.59 -41.64,28.62 -11.77,11.95 -20.95,26.12 -27.64,42.44 -6.69,16.23 -10.07,33.53 -10.07,51.89z"/>
            <path fill="#FF7416" d="M313.71 252.93l0 32.06 -31.77 18.34 -23.77 13.72c0,-0 -0,-0 -0,-0l0 -64.12 55.54 -32.07 0 32.06zm0 67.89l0 77.75 -55.54 0 0 -63.56 55.54 -32.07 0 17.88zm-71.55 77.75l-55.54 0 0 -59.79 0 -0.08 0 -35.76 55.54 32.06 0.01 63.57zm8 -159.51l55.54 -32.07 -23.76 -13.72 -31.78 -18.34 -55.53 32.06 55.53 32.06z"/>
            <polygon fill="#FF7416" points="242.16,317.06 242.16,252.93 186.62,220.87 186.63,285 "/>
          </svg>
        </div>
        <span class="inline-block bg-accent text-white font-mono font-bold px-3 py-1 mb-6 text-sm uppercase border border-accent">О компании</span>
        <h1 class="text-4xl sm:text-5xl font-extrabold leading-none mb-6 uppercase tracking-tight relative z-10">
          Больше за меньшие деньги
        </h1>
        <p class="text-gray-300 text-xl max-w-2xl border-l-2 border-accent pl-4 relative z-10">
          Наша миссия - дать людям возможность сэкономить на ремонте, делясь с ними скидками, которые мы получаем от производителей.
        </p>
      </div>

      <!-- Как это работает -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="brutal-card p-8 bg-white">
          <h2 class="text-2xl font-extrabold uppercase text-brand mb-6 border-b-2 border-brand pb-2">Как мы делаем цены ниже</h2>
          <div class="space-y-4 text-gray-700">
            <p class="font-medium">
              Обычная розничная сеть работает по схеме: <strong class="text-brand">завод → склад → магазин → покупатель</strong>. На каждом этапе добавляется наценка: аренда склада, содержание торгового зала, зарплата продавцов, потери от хранения.
            </p>
            <p class="font-medium">
              Мы убрали лишние звенья. <strong class="text-brand">Завод → СнобСнаб → покупатель</strong>. У нас нет складов с товарными остатками. Нет торговых залов. Нет расходов на хранение и администрирование товара.
            </p>
            <p class="font-medium">
              Это позволяет нам делиться с вами той маржой, которую обычно забирают магазины. Вы получаете те же бренды и то же качество - но <strong class="text-accent">на 30% дешевле</strong>.
            </p>
          </div>
        </div>

        <div class="brutal-card p-8 bg-white">
          <h2 class="text-2xl font-extrabold uppercase text-brand mb-6 border-b-2 border-brand pb-2">Win-Win для всех</h2>
          <div class="space-y-4 text-gray-700">
            <div class="border-l-4 border-accent pl-4 py-2">
              <p class="font-extrabold text-brand uppercase text-sm mb-1">Вы экономите</p>
              <p class="font-medium">Получаете материалы для ремонта по ценам, недоступным в розничных магазинах. Экономия до 30% на каждой позиции.</p>
            </div>
            <div class="border-l-4 border-accent pl-4 py-2">
              <p class="font-extrabold text-brand uppercase text-sm mb-1">Производители продают</p>
              <p class="font-medium">Заводы получают стабильный канал сбыта без посредников. Прямые договоры - прямые отгрузки.</p>
            </div>
            <div class="border-l-4 border-accent pl-4 py-2">
              <p class="font-extrabold text-brand uppercase text-sm mb-1">Мы зарабатываем</p>
              <p class="font-medium">Наша комиссия минимальна - мы берём за логистику и подбор, а не за хранение и витрину.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Цифры -->
      <div class="brutal-card p-8 bg-accent text-brand mb-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div>
            <p class="text-5xl font-extrabold font-mono">50+</p>
            <p class="text-sm font-bold uppercase mt-2">заводов-партнёров</p>
          </div>
          <div>
            <p class="text-5xl font-extrabold font-mono">30%</p>
            <p class="text-sm font-bold uppercase mt-2">экономия на ремонте</p>
          </div>
          <div>
            <p class="text-5xl font-extrabold font-mono">0₽</p>
            <p class="text-sm font-bold uppercase mt-2">за консультацию</p>
          </div>
          <div>
            <p class="text-5xl font-extrabold font-mono">от 7</p>
            <p class="text-sm font-bold uppercase mt-2">дней доставка</p>
          </div>
        </div>
      </div>

      <!-- Почему мы -->
      <div class="brutal-card p-8 bg-white mb-12">
        <h2 class="text-2xl font-extrabold uppercase text-brand mb-8 border-b-2 border-brand pb-2">Почему выбирают нас</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="border-2 border-brand p-6 hover:border-accent transition-colors">
            <p class="text-4xl font-extrabold font-mono text-accent mb-3">01.</p>
            <h3 class="font-extrabold uppercase text-brand mb-2">Прямые договоры</h3>
            <p class="text-gray-600 font-medium">Работаем напрямую с производителями - без посредников, без перекупов, без лишних наценок.</p>
          </div>
          <div class="border-2 border-brand p-6 hover:border-accent transition-colors">
            <p class="text-4xl font-extrabold font-mono text-accent mb-3">02.</p>
            <h3 class="font-extrabold uppercase text-brand mb-2">Нет складских расходов</h3>
            <p class="text-gray-600 font-medium">Мы не храним товары - заказываем под ваш проект. Экономим на хранении и передаём эту экономию вам.</p>
          </div>
          <div class="border-2 border-brand p-6 hover:border-accent transition-colors">
            <p class="text-4xl font-extrabold font-mono text-accent mb-3">03.</p>
            <h3 class="font-extrabold uppercase text-brand mb-2">Любой объём</h3>
            <p class="text-gray-600 font-medium">От одной коробки плитки до полной комплектации ремонта - работаем с любыми заказами.</p>
          </div>
          <div class="border-2 border-brand p-6 hover:border-accent transition-colors">
            <p class="text-4xl font-extrabold font-mono text-accent mb-3">04.</p>
            <h3 class="font-extrabold uppercase text-brand mb-2">Доставка до двери</h3>
            <p class="text-gray-600 font-medium">Привезём материалы в удобное время прямо к подъезду. По Кемерово и всему Кузбассу.</p>
          </div>
          <div class="border-2 border-brand p-6 hover:border-accent transition-colors">
            <p class="text-4xl font-extrabold font-mono text-accent mb-3">05.</p>
            <h3 class="font-extrabold uppercase text-brand mb-2">Бесплатная консультация</h3>
            <p class="text-gray-600 font-medium">Поможем подобрать материалы под ваш проект и бюджет. Рассчитаем смету - бесплатно.</p>
          </div>
          <div class="border-2 border-brand p-6 hover:border-accent transition-colors">
            <p class="text-4xl font-extrabold font-mono text-accent mb-3">06.</p>
            <h3 class="font-extrabold uppercase text-brand mb-2">Любая форма оплаты</h3>
            <p class="text-gray-600 font-medium">Наличные, перевод, по счёту для юрлиц - как вам удобно. Договор и закрывающие документы.</p>
          </div>
        </div>
      </div>

      <!-- География -->
      <div class="brutal-card p-8 bg-white mb-12">
        <h2 class="text-2xl font-extrabold uppercase text-brand mb-6 border-b-2 border-brand pb-2">География работы</h2>
        <div class="space-y-3 text-gray-700 font-medium max-w-2xl">
          <p>Основной регион - <strong class="text-brand">Кемерово и Кемеровская область</strong> (Кузбасс). Доставляем в Новокузнецк, Прокопьевск, Ленинск-Кузнецкий, Междуреченск, Белово и другие города области.</p>
          <p>Также работаем по всей <strong class="text-brand">России</strong> - отгрузка транспортными компаниями от 5-7 рабочих дней.</p>
        </div>
      </div>

      <!-- CTA -->
      <div class="brutal-card p-8 lg:p-12 bg-brand text-white text-center">
        <h2 class="text-3xl font-extrabold uppercase mb-4">Готовы сэкономить на ремонте?</h2>
        <p class="text-gray-300 mb-8 max-w-lg mx-auto">Пришлите нам список материалов или смету - мы покажем, сколько вы сэкономите по сравнению с магазинами.</p>
        <a href="/#contact" class="inline-block brutal-button px-10 py-4 bg-white text-brand border-white hover:bg-accent hover:text-white hover:border-brand text-lg">
          Рассчитать смету
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

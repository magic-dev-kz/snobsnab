---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

// Загружаем последние 3 статьи из коллекции
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);

// Заглушки на случай если статей ещё нет
const fallbackPosts = [
  { id: 'f1', data: { title: 'Сравнение утеплителей: Минвата vs XPS', description: 'Подробный разбор характеристик, цен и областей применения самых популярных утеплителей на строительном рынке Кузбасса.', category: 'Технологии', date: '', icon: '🏗️', ogImage: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&q=80&w=800' }},
  { id: 'f2', data: { title: 'Профлист или металлочерепица: что выбрать для кровли', description: 'Аналитика от экспертов СнобСнаб. Детальное сравнение двух лидеров рынка кровельных материалов.', category: 'Кровля', date: '', icon: '🏠', ogImage: 'https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=800' }},
  { id: 'f3', data: { title: '5 ошибок при заливке фундамента', description: 'Разбираем самые частые ошибки подрядчиков и как их избежать при строительстве в условиях Кузбасса.', category: 'Инструкции', date: '', icon: '💧', ogImage: 'https://images.unsplash.com/photo-1589939705384-5185137a7f0f?auto=format&fit=crop&q=80&w=800' }},
];

const displayPosts = latestPosts.length > 0 ? latestPosts : fallbackPosts;

const categories = [
  { name: 'Сантехника', desc: 'Смесители, унитазы, ванны, раковины', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path d="M9 22V12h6v10"/></svg>` },
  { name: 'Покрытия полов', desc: 'Ламинат, линолеум, плитка, подложка', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>` },
  { name: 'Керамика', desc: 'Плитка для ванной, кухни, керамогранит', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20h18"/><path d="M5 20V9l7-6 7 6v11"/><path d="M10 20v-5h4v5"/><path d="M9 9h6"/></svg>` },
  { name: 'Краски', desc: 'Для стен, потолков, декоративные', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 7h18M3 12h18M3 17h18"/></svg>` },
  { name: 'Обои и декор', desc: 'Рулонные, жидкие, фотообои, декоративка', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>` },
  { name: 'Освещение', desc: 'Люстры, светильники, лампы, LED', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>` },
];

const advantages = [
  { title: 'Прямые поставки', desc: 'Работаем с производителями напрямую — без посредников и наценок', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>` },
  { title: 'Цены ниже рынка', desc: 'Отсутствие склада и прямые контракты позволяют держать минимальные цены', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>` },
  { title: 'Доставка 5-7 дней', desc: 'Оперативная логистика по всему Кузбассу и Сибири', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>` },
  { title: 'Комплексное снабжение', desc: 'Одна заявка — все материалы. Не нужно искать десятки поставщиков', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>` },
  { title: 'Индивидуальный подход', desc: 'Подберём оптимальные материалы под ваш проект и бюджет', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>` },
  { title: 'Работаем с юрлицами', desc: 'Полный документооборот, НДС, отсрочка платежа для постоянных клиентов', svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>` },
];
---

<BaseLayout title="СнобСнаб — стройматериалы с доставкой до двери в Кемерово">
  
  <!-- Hero Section (Petrovich style: banners, catalog grid, e-com layout) -->
  <section class="bg-brand-light pt-8 pb-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Top split: Main Banner + Quick Links -->
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-12">
        <!-- Main Promo Banner -->
        <div class="lg:col-span-3 bg-brand rounded-2xl p-8 sm:p-12 relative overflow-hidden flex flex-col justify-center min-h-[300px]">
          <div class="relative z-10">
            <span class="inline-block bg-accent text-white font-bold px-3 py-1 rounded mb-4 text-sm uppercase">Доставка до двери</span>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-4">
              Стройматериалы<br/>
              <span class="text-accent">напрямую с заводов</span>
            </h1>
            <p class="text-gray-300 text-lg mb-8 max-w-md">
              Рассчитаем смету. Мы не храним товары на складах, поэтому наши цены ниже рыночных. Делимся прибылью с вами.
            </p>
            <a href="#contact" class="inline-block bg-accent text-white font-bold px-8 py-3 rounded-lg hover:bg-accent-hover transition-colors">
              Рассчитать смету
            </a>
          </div>
          <!-- Abstract Background Element -->
          <div class="absolute right-0 bottom-0 opacity-20 w-64 h-64 bg-accent rounded-full blur-3xl transform translate-x-1/3 translate-y-1/3"></div>
        </div>

        <!-- Quick Side Banners (Info cards) -->
        <div class="lg:col-span-1 flex flex-col gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex-1 flex flex-col justify-center hover:shadow-md transition-shadow">
            <div class="w-8 h-8 text-accent mb-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <h3 class="font-bold text-dark text-lg mb-1">Доставка на объект</h3>
            <p class="text-sm text-gray-500">Фуры и манипуляторы от 5 до 20 тонн. Строго по графику.</p>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex-1 flex flex-col justify-center hover:shadow-md transition-shadow">
            <div class="w-8 h-8 text-accent mb-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <h3 class="font-bold text-dark text-lg mb-1">Работаем с НДС</h3>
            <p class="text-sm text-gray-500">Полный пакет документов для юрлиц. Договор, ЭДО.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-surface py-6 border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl font-bold text-brand">50+</p>
          <p class="text-gray-500 text-sm">производителей-партнёров</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-brand">5-7</p>
          <p class="text-gray-500 text-sm">дней доставка</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-brand">24/7</p>
          <p class="text-gray-500 text-sm">приём заявок</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-brand">30%</p>
          <p class="text-gray-500 text-sm">выгода от цен в розничных сетях</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Catalog Grid -->
  <section id="catalog" class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-8">
        <h2 class="text-3xl font-bold text-dark">Каталог строительных материалов</h2>
        <a href="#contact" class="text-accent font-semibold hover:text-accent-hover hidden sm:block">Узнать цены →</a>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {categories.map((cat) => (
          <a href="#contact" class="group bg-brand-light rounded-xl p-6 text-center hover:bg-white hover:shadow-lg border border-transparent hover:border-gray-200 transition-all duration-200 cursor-pointer flex flex-col items-center justify-center h-48">
            <div class="w-12 h-12 mb-4 text-dark group-hover:text-accent transition-colors transform group-hover:scale-110 duration-200" set:html={cat.svg} />
            <h3 class="text-sm font-bold text-dark group-hover:text-accent transition-colors leading-snug">{cat.name}</h3>
          </a>
        ))}
      </div>
      <a href="#contact" class="mt-6 block sm:hidden text-center text-accent font-semibold">Узнать цены →</a>
    </div>
  </section>

  <!-- SEO Blog Section -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-8">
        <div>
          <h2 class="text-3xl font-bold text-dark mb-2">База знаний и новости</h2>
          <p class="text-gray-500">Полезные материалы для строителей и прорабов</p>
        </div>
        <a href="/blog" class="text-accent font-semibold hover:text-accent-hover hidden sm:block">Все статьи →</a>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        {displayPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            url={latestPosts.length > 0 ? `/blog/${post.id}/` : '#'}
            image={post.data.ogImage}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Advantages -->
  <section id="advantages" class="py-12 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-dark mb-8">Почему выгодно работать с нами</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {advantages.map((adv) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex items-start gap-4 group hover:border-accent hover:shadow-md transition-all duration-200">
            <div class="flex-shrink-0 bg-brand-light w-14 h-14 flex items-center justify-center rounded-xl group-hover:bg-accent transition-colors duration-200">
              <div class="w-7 h-7 text-dark group-hover:text-white transition-colors duration-200" set:html={adv.svg} />
            </div>
            <div>
              <h3 class="text-lg font-bold text-dark mb-2">{adv.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed">{adv.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works / Contact CTA -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand rounded-3xl p-8 md:p-16 flex flex-col md:flex-row items-center justify-between gap-12 overflow-hidden relative">
        <!-- Abstract BG -->
        <div class="absolute right-0 top-0 opacity-10 w-96 h-96 bg-white rounded-full blur-3xl transform translate-x-1/3 -translate-y-1/3"></div>
        
        <div class="relative z-10 md:w-1/2 text-white">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Смета дешевле, чем в <span class="text-accent">Леруа и других розничных сетях</span></h2>
          <p class="text-gray-300 text-lg mb-8">
            Пришлите нам смету от вашего текущего поставщика или список необходимых материалов. Мы сделаем расчёт с оптовыми скидками от заводов.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full bg-accent text-white flex items-center justify-center text-sm font-bold">1</span>
              <span>Вы отправляете заявку или смету</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full bg-accent text-white flex items-center justify-center text-sm font-bold">2</span>
              <span>Мы считаем цены со скидкой до 30%</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full bg-accent text-white flex items-center justify-center text-sm font-bold">3</span>
              <span>Доставляем фурами прямо на объект</span>
            </li>
          </ul>
        </div>

        <!-- Form Block -->
        <div id="contact" class="relative z-10 md:w-5/12 w-full bg-white rounded-2xl p-8 shadow-xl">
          <h3 class="text-2xl font-bold text-dark mb-6">Заявка на расчёт</h3>
          <form class="space-y-5">
            <div>
              <input type="text" placeholder="Ваше имя или название компании" class="w-full px-4 py-3 bg-brand-light border-none rounded-xl focus:ring-2 focus:ring-accent outline-none text-dark" />
            </div>
            <div>
              <input type="tel" placeholder="Номер телефона" class="w-full px-4 py-3 bg-brand-light border-none rounded-xl focus:ring-2 focus:ring-accent outline-none text-dark" />
            </div>
            <div>
              <textarea placeholder="Что нужно привезти? (или прикрепите ссылку на смету)" rows="3" class="w-full px-4 py-3 bg-brand-light border-none rounded-xl focus:ring-2 focus:ring-accent outline-none text-dark resize-none"></textarea>
            </div>
            <button type="submit" class="w-full bg-accent text-white font-bold py-4 rounded-xl text-lg hover:bg-accent-hover transition-colors shadow-md">
              Получить расчёт
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- About Company -->
  <section class="py-16 bg-brand text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">СНОБСНАБ</h2>
      <p class="text-gray-300 text-lg max-w-3xl mx-auto mb-4">
        СнобСнаб - это оптовая компания по продаже строительных и отделочных материалов. Мы специализируемся на снабжении и комплектации строительных объектов по Кемерово и области, а также работаем по всей России.
      </p>
      <p class="text-gray-300 text-lg max-w-3xl mx-auto">
        Объединяем возможности производителей и потребности застройщиков через прямые контракты - без посредников и складских наценок.
      </p>
    </div>
  </section>

  <!-- How We Work (Этапы) -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-dark text-center mb-4">Как мы работаем</h2>
      <p class="text-gray-500 text-center mb-12">5 простых шагов от заявки до доставки</p>
      
      <!-- Desktop: горизонтальный таймлайн -->
      <div class="hidden md:block">
        <div class="relative">
          <!-- Горизонтальная линия -->
          <div class="absolute top-8 left-[10%] right-[10%] h-0.5 bg-gray-200"></div>
          <div class="absolute top-8 left-[10%] right-[10%] h-0.5 bg-accent origin-left" style="transform: scaleX(1)"></div>
          
          <div class="grid grid-cols-5 gap-4">
            <div class="flex flex-col items-center text-center">
              <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center text-white text-xl font-bold z-10 shadow-lg shadow-orange-200 ring-4 ring-white">1</div>
              <h3 class="text-lg font-bold text-dark mt-4 mb-2">Заявка</h3>
              <p class="text-sm text-gray-500">Оставьте заявку через форму или по телефону</p>
            </div>
            <div class="flex flex-col items-center text-center">
              <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center text-white text-xl font-bold z-10 shadow-lg shadow-orange-200 ring-4 ring-white">2</div>
              <h3 class="text-lg font-bold text-dark mt-4 mb-2">Консультация</h3>
              <p class="text-sm text-gray-500">Бесплатный звонок менеджера: цели, задачи, бюджет</p>
            </div>
            <div class="flex flex-col items-center text-center">
              <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center text-white text-xl font-bold z-10 shadow-lg shadow-orange-200 ring-4 ring-white">3</div>
              <h3 class="text-lg font-bold text-dark mt-4 mb-2">КП</h3>
              <p class="text-sm text-gray-500">Индивидуальное предложение с ценой и сроками</p>
            </div>
            <div class="flex flex-col items-center text-center">
              <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center text-white text-xl font-bold z-10 shadow-lg shadow-orange-200 ring-4 ring-white">4</div>
              <h3 class="text-lg font-bold text-dark mt-4 mb-2">Договор</h3>
              <p class="text-sm text-gray-500">Согласуем детали и подпишем документы</p>
            </div>
            <div class="flex flex-col items-center text-center">
              <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center text-white text-xl font-bold z-10 shadow-lg shadow-orange-200 ring-4 ring-white">5</div>
              <h3 class="text-lg font-bold text-dark mt-4 mb-2">Доставка</h3>
              <p class="text-sm text-gray-500">Привезём материалы фурами прямо на объект</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile: вертикальный таймлайн -->
      <div class="md:hidden">
        <div class="relative pl-8">
          <!-- Вертикальная линия -->
          <div class="absolute left-3 top-0 bottom-0 w-0.5 bg-accent"></div>
          
          <div class="space-y-8">
            <div class="relative">
              <div class="absolute -left-8 w-7 h-7 bg-accent rounded-full flex items-center justify-center text-white text-sm font-bold ring-2 ring-white">1</div>
              <h3 class="text-lg font-bold text-dark mb-1">Заявка</h3>
              <p class="text-sm text-gray-500">Оставьте заявку через форму или по телефону</p>
            </div>
            <div class="relative">

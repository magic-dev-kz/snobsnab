---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import HowWeWork from '../components/HowWeWork.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

// Иконки
import IconPlumbing from '../components/icons/IconPlumbing.astro';
import IconFlooring from '../components/icons/IconFlooring.astro';
import IconCeramics from '../components/icons/IconCeramics.astro';
import IconPaint from '../components/icons/IconPaint.astro';
import IconWallpaper from '../components/icons/IconWallpaper.astro';
import IconLighting from '../components/icons/IconLighting.astro';

import IconDirect from '../components/icons/IconDirect.astro';
import IconPrice from '../components/icons/IconPrice.astro';
import IconDeliveryFast from '../components/icons/IconDeliveryFast.astro';
import IconComplex from '../components/icons/IconComplex.astro';
import IconPersonal from '../components/icons/IconPersonal.astro';
import IconLegal from '../components/icons/IconLegal.astro';

// Загружаем последние 3 статьи из коллекции
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);

// Заглушки на случай если статей ещё нет
const fallbackPosts = [
  { id: 'f1', data: { title: 'Сравнение утеплителей: Минвата vs XPS', description: 'Подробный разбор характеристик, цен и областей применения.', category: 'Технологии', date: '', ogImage: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&q=80&w=800' }},
  { id: 'f2', data: { title: 'Профлист или металлочерепица: что выбрать', description: 'Аналитика от экспертов СнобСнаб. Детальное сравнение.', category: 'Кровля', date: '', ogImage: 'https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=800' }},
  { id: 'f3', data: { title: '5 ошибок при заливке фундамента', description: 'Самые частые ошибки подрядчиков и как их избежать.', category: 'Инструкции', date: '', ogImage: 'https://images.unsplash.com/photo-1589939705384-5185137a7f0f?auto=format&fit=crop&q=80&w=800' }},
];
const displayPosts = latestPosts.length > 0 ? latestPosts : fallbackPosts;

const categories = [
  { name: 'Сантехника', Component: IconPlumbing },
  { name: 'Покрытия полов', Component: IconFlooring },
  { name: 'Керамика', Component: IconCeramics },
  { name: 'Краски', Component: IconPaint },
  { name: 'Обои и декор', Component: IconWallpaper },
  { name: 'Освещение', Component: IconLighting },
];

const advantages = [
  { title: 'Прямые поставки', desc: 'Работаем с производителями напрямую — без посредников и наценок', Component: IconDirect },
  { title: 'Цены ниже рынка', desc: 'Отсутствие склада и прямые контракты позволяют держать минимальные цены', Component: IconPrice },
  { title: 'Доставка 5-7 дней', desc: 'Оперативная логистика по всему Кузбассу и Сибири', Component: IconDeliveryFast },
  { title: 'Комплексное снабжение', desc: 'Одна заявка — все материалы. Не нужно искать десятки поставщиков', Component: IconComplex },
  { title: 'Индивидуальный подход', desc: 'Подберём оптимальные материалы под ваш проект и бюджет', Component: IconPersonal },
  { title: 'Работаем с юрлицами', desc: 'Полный документооборот, НДС, отсрочка платежа для постоянных клиентов', Component: IconLegal },
];
---

<BaseLayout title="СнобСнаб — Стройматериалы Кемерово">
  
  <!-- HERO (Brutalism) -->
  <section class="py-12 border-b-2 border-brand relative overflow-hidden bg-brand-light">
    <!-- Декоративный фон из логотипа (Watermark) -->
    <div class="absolute -right-24 top-1/2 -translate-y-1/2 w-[600px] h-[600px] opacity-10 pointer-events-none z-0">
      <svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full text-brand">
        <!-- Внешнее кольцо -->
        <path fill="currentColor" d="M45.8 250.44c0,-18.73 2.4,-36.83 7.22,-54.3 4.82,-17.48 11.68,-33.79 20.6,-48.95 8.92,-15.16 19.61,-28.98 32.01,-41.46 12.4,-12.48 26.12,-23.18 41.28,-32.01 15.16,-8.83 31.48,-15.69 48.86,-20.6 17.39,-4.9 35.49,-7.31 54.39,-7.31 18.72,0 36.82,2.41 54.21,7.31 17.38,4.9 33.61,11.77 48.77,20.6 15.16,8.83 28.98,19.53 41.46,32.01 12.48,12.48 23.18,26.3 32.01,41.46 8.83,15.16 15.69,31.48 20.6,48.95 4.91,17.48 7.31,35.58 7.31,54.3 0,18.9 -2.4,37 -7.31,54.39 -4.9,17.39 -11.77,33.62 -20.6,48.68 -8.83,15.07 -19.53,28.8 -32.01,41.19 -12.49,12.4 -26.31,23.1 -41.46,32.01 -15.16,8.92 -31.39,15.78 -48.77,20.6 -17.39,4.82 -35.49,7.22 -54.21,7.22 -18.9,0 -37,-2.41 -54.39,-7.22 -17.39,-4.82 -33.7,-11.68 -48.86,-20.6 -15.16,-8.91 -28.89,-19.61 -41.28,-32.01 -12.4,-12.39 -23.09,-26.12 -32.01,-41.19 -8.92,-15.07 -15.78,-31.3 -20.6,-48.68 -4.82,-17.39 -7.22,-35.49 -7.22,-54.39zm73.29 0c0,18.55 3.39,35.84 10.07,51.89 6.69,16.14 15.87,30.23 27.64,42.18 11.77,12.04 25.68,21.49 41.64,28.44 15.96,6.95 33.17,10.43 51.72,10.43 18.37,0 35.58,-3.48 51.53,-10.43 15.96,-6.96 29.79,-16.41 41.55,-28.44 11.77,-11.95 21.05,-26.04 27.82,-42.18 6.78,-16.05 10.16,-33.35 10.16,-51.89 0,-18.37 -3.39,-35.67 -10.16,-51.89 -6.77,-16.32 -16.05,-30.49 -27.82,-42.44 -11.77,-12.04 -25.59,-21.58 -41.55,-28.62 -15.96,-7.04 -33.17,-10.52 -51.53,-10.52 -18.55,0 -35.76,3.48 -51.72,10.52 -15.96,7.05 -29.87,16.59 -41.64,28.62 -11.77,11.95 -20.95,26.12 -27.64,42.44 -6.69,16.23 -10.07,33.53 -10.07,51.89z"/>
        <!-- Внутренний домик (параллелограммы) -->
        <path fill="currentColor" d="M313.71 252.93l0 32.06 -31.77 18.34 -23.77 13.72c0,-0 -0,-0 -0,-0l0 -64.12 55.54 -32.07 0 32.06zm0 67.89l0 77.75 -55.54 0 0 -63.56 55.54 -32.07 0 17.88zm-71.55 77.75l-55.54 0 0 -59.79 0 -0.08 0 -35.76 55.54 32.06 0.01 63.57zm8 -159.51l55.54 -32.07 -23.76 -13.72 -31.78 -18.34 -55.53 32.06 55.53 32.06z"/>
        <polygon fill="currentColor" points="242.16,317.06 242.16,252.93 186.62,220.87 186.63,285 "/>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="flex flex-col lg:flex-row gap-8">
        
        <!-- Main Hero -->
        <div class="lg:w-3/4 brutal-card p-8 lg:p-12 bg-[#1A1A1A] text-white relative overflow-hidden">
          <!-- Во внутренний блок тоже можно добавить очень бледную подложку для глубины, если нужно, но по заданию - на фон самой секции. Оставим секции. -->
          <span class="inline-block bg-accent text-white font-mono font-bold px-3 py-1 mb-6 text-sm uppercase border border-accent relative z-10">Доставка до двери</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-none mb-6 uppercase tracking-tight relative z-10">
            Материалы для ремонта<br/>
            <span class="text-accent">на 30% дешевле</span> магазинов
          </h1>
          <p class="text-gray-300 text-lg mb-8 max-w-2xl border-l-2 border-accent pl-4">
            Работаем напрямую с производителями - без складов и наценок. Делимся прибылью с вами.
          </p>
          <a href="#contact" class="inline-block brutal-button px-8 py-4">
            Рассчитать смету
          </a>
        </div>

        <!-- Right blocks -->
        <div class="lg:w-1/4 flex flex-col gap-6">
          <div class="brutal-card p-6 flex flex-col justify-center h-full">
            <IconDeliveryFast class="w-10 h-10 text-brand mb-4" />
            <h3 class="font-bold text-xl uppercase mb-2">На объект</h3>
            <p class="text-sm text-gray-600">Любой объём - от одной коробки до полной комплектации ремонта.</p>
          </div>
          <div class="brutal-card p-6 flex flex-col justify-center h-full">
            <IconLegal class="w-10 h-10 text-brand mb-4" />
            <h3 class="font-bold text-xl uppercase mb-2">Для юрлиц</h3>
            <p class="text-sm text-gray-600">С НДС, договор, закрывающие документы.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="py-8 border-b-2 border-brand bg-accent">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center text-brand">
        <div class="border-r-2 border-brand/20 last:border-0">
          <p class="text-4xl font-extrabold font-mono">50+</p>
          <p class="text-sm font-bold uppercase mt-1">заводов</p>
        </div>
        <div class="border-r-2 border-brand/20 md:last:border-0">
          <p class="text-4xl font-extrabold font-mono">от 7</p>
          <p class="text-sm font-bold uppercase mt-1">дней доставка</p>
        </div>
        <div class="border-r-2 border-brand/20 last:border-0">
          <p class="text-4xl font-extrabold font-mono">0₽</p>
          <p class="text-sm font-bold uppercase mt-1">консультация</p>
        </div>
        <div>
          <p class="text-4xl font-extrabold font-mono">30%</p>
          <p class="text-sm font-bold uppercase mt-1">экономия</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CATALOG -->
  <section id="catalog" class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-10 border-b-2 border-brand pb-4">
        <h2 class="text-3xl font-extrabold uppercase tracking-tight">Каталог материалов</h2>
        <a href="#contact" class="hidden sm:block font-bold hover:text-accent font-mono uppercase text-sm border border-brand px-3 py-1 bg-white hover:bg-brand hover:text-white transition-colors">Узнать цены →</a>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        {categories.map((cat) => (
          <a href="#contact" class="brutal-card p-6 flex flex-col items-start gap-4 group cursor-pointer">
            <cat.Component class="w-12 h-12 text-brand" />
            <h3 class="font-bold text-sm tracking-wide uppercase group-hover:text-accent transition-colors">{cat.name}</h3>
          </a>
        ))}
      </div>
      <a href="#contact" class="mt-8 block sm:hidden text-center brutal-button py-3">Узнать цены</a>
    </div>
  </section>

  <!-- BLOG (SEO) -->
  <section class="py-16 border-t-2 border-brand">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-10 border-b-2 border-brand pb-4">
        <div>
          <h2 class="text-3xl font-extrabold uppercase tracking-tight mb-2">Блог о строительстве</h2>
          <p class="text-gray-600 font-medium">Полезные статьи о выборе материалов, технологиях и экономии для строителей и заказчиков в Сибири</p>
        </div>
        <a href="/blog" class="hidden sm:block font-bold hover:text-accent font-mono uppercase text-sm border border-brand px-3 py-1 bg-white hover:bg-brand hover:text-white transition-colors whitespace-nowrap">Все статьи →</a>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        {displayPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            url={latestPosts.length > 0 ? `/blog/${post.id}/` : '#'}
            image={post.data.ogImage}
          />
        ))}
      </div>
      <a href="/blog" class="mt-8 block sm:hidden text-center brutal-button py-3">Все статьи →</a>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <HowWeWork />

  <!-- ADVANTAGES -->
  <section id="advantages" class="py-16 bg-brand text-white border-y-2 border-brand">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold uppercase tracking-tight mb-10 border-l-4 border-accent pl-4">Почему мы</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {advantages.map((adv) => (
          <div class="border-2 border-white p-6 bg-[#1A1A1A] hover:bg-white hover:text-brand transition-colors group">
            <adv.Component class="w-10 h-10 mb-4 text-accent group-hover:text-accent" />
            <h3 class="text-xl font-bold uppercase mb-2">{adv.title}</h3>
            <p class="text-sm text-gray-400 group-hover:text-gray-600">{adv.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT COMPANY -->
  <section class="py-16 bg-white border-b-2 border-brand relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="brutal-card p-8 md:p-12">
        <h2 class="text-3xl md:text-4xl font-extrabold uppercase tracking-tight mb-6 border-b-2 border-brand pb-4 inline-block">СНОБСНАБ</h2>
        <div class="space-y-4 text-lg text-gray-800 font-medium max-w-5xl">
          <p>
            СнобСнаб - это компания по продаже строительных и отделочных материалов по ценам производителей. Мы специализируемся на комплектации ремонтов и строительных объектов по Кемерово и области, а также работаем по всей России.
          </p>
          <p>
            Объединяем возможности производителей и потребности застройщиков через прямые контракты - без посредников и складских наценок.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORM / CTA -->
  <section class="py-20 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="brutal-card p-0 flex flex-col md:flex-row">
        
        <div class="md:w-1/2 p-8 md:p-16 bg-accent border-b-2 md:border-b-0 md:border-r-2 border-brand flex flex-col justify-center">
          <h2 class="text-3xl md:text-5xl font-extrabold mb-6 uppercase text-brand leading-none">Те же бренды - другие цены</h2>
          <p class="text-brand text-lg mb-8 font-medium">
            Пришлите нам смету или список материалов. Мы сделаем расчёт со скидками напрямую от заводов.
          </p>
          <ul class="space-y-4 font-bold text-brand">
            <li class="flex items-center gap-3">
              <span class="font-mono text-xl bg-brand text-white w-8 h-8 flex items-center justify-center border-2 border-brand">1</span> 
              Отправляете заявку
            </li>
            <li class="flex items-center gap-3">
              <span class="font-mono text-xl bg-brand text-white w-8 h-8 flex items-center justify-center border-2 border-brand">2</span> 
              Считаем со скидкой 30%
            </li>
            <li class="flex items-center gap-3">
              <span class="font-mono text-xl bg-brand text-white w-8 h-8 flex items-center justify-center border-2 border-brand">3</span> 
              Доставляем на объект
            </li>
          </ul>
        </div>

        <div id="contact" class="md:w-1/2 p-8 md:p-16 bg-white">
          <h3 class="text-2xl font-bold uppercase mb-6 border-b-2 border-brand pb-2 inline-block">Заявка на расчёт</h3>
          <form class="space-y-6">
            <div>
              <label class="block text-xs font-bold uppercase mb-2">Имя / Компания</label>
              <input type="text" class="w-full px-4 py-3 brutal-input" />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase mb-2">Телефон</label>
              <input type="tel" class="w-full px-4 py-3 brutal-input" />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase mb-2">Что нужно привезти (или ссылка)</label>
              <textarea rows="3" class="w-full px-4 py-3 brutal-input resize-none"></textarea>
            </div>
            <button type="submit" class="w-full brutal-button py-4 text-lg mt-4">
              Получить расчёт
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Scroll to Top Button -->
  <button id="scrollTopBtn" class="fixed bottom-8 right-8 w-14 h-14 bg-brand text-white border-2 border-brand shadow-[4px_4px_0px_#FF7416] hidden items-center justify-center hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_#FF7416] hover:bg-accent transition-all z-50 group" aria-label="Наверх">
    <svg class="w-6 h-6 transform group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" d="M5 15l7-7 7 7"/></svg>
  </button>

  <script>
    const btn = document.getElementById('scrollTopBtn');
    if (btn) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 500) {
          btn.classList.remove('hidden');
          btn.classList.add('flex');
        } else {
          btn.classList.add('hidden');
          btn.classList.remove('flex');
        }
      });
      btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }
  </script>

</BaseLayout>
